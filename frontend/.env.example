# Local dev FastAPI origin, without a trailing slash.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Production behind same-domain Nginx/proxy:
# VITE_API_BASE_URL=
#
# Browser camera/microphone access requires HTTPS, except localhost.
# If the API is on another domain, use https://... so interview WebSocket uses wss://...
