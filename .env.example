# ========================
# Application Settings
# ========================
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
# Logging: leave unset for ./logs under project root; set LOG_TO_FILE=false for stdout-only (e.g. read-only containers)
# LOG_DIR=/var/log/lancerai
# LOG_TO_FILE=true

# ========================
# Auth / JWT
# ========================
# REQUIRED — change to a strong random string (>= 32 chars) for production
AUTH_SECRET_KEY=change-me-in-production
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=60
AUTH_REFRESH_TOKEN_TTL_DAYS=7
# Dev only: set true to skip key-length check. MUST be false in production.
AUTH_ALLOW_WEAK_SECRET=true

# ========================
# CORS
# ========================
# Comma-separated origins. For local dev with Vite frontend:
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Production example:
# ALLOWED_ORIGINS=["https://lancerai.com","https://app.lancerai.com"]

# ========================
# Database (PostgreSQL) — REQUIRED
# ========================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lancerai
DATABASE_ECHO=false

# ========================
# Redis (Cache + Message Broker)
# ========================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========================
# Vector Database (ChromaDB / Qdrant)
# ========================
# Use http:// scheme for Docker ChromaDB (docker-compose maps host 8001 -> container 8000).
# IMPORTANT: use "http://localhost" (NOT bare "localhost") to avoid creating a local folder.
VECTOR_DB_HOST=http://localhost
VECTOR_DB_PORT=8001
VECTOR_DB_COLLECTION=cv_embeddings
# Backend selector: chroma (default) | qdrant
VECTOR_DB_BACKEND=chroma
# API key — required for Qdrant Cloud or Chroma Cloud, leave empty for local
VECTOR_DB_API_KEY=

# ========================
# Knowledge Graph (Neo4j) — REQUIRED
# ========================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ========================
# Local LLM (Ollama)
# ========================
LLM_LOCAL_BASE_URL=http://localhost:11434
LLM_LOCAL_MODEL=qwen2.5:3b

# ========================
# Cloud LLM (Fallback - Groq API)
# ========================
LLM_CLOUD_API_KEY=your-groq-api-key
LLM_CLOUD_BASE_URL=https://api.groq.com/openai/v1
LLM_CLOUD_MODEL=llama-3.1-70b-versatile

# ========================
# NVIDIA NIM API (Primary Cloud LLM)
# Get API key at: https://build.nvidia.com/
# ========================
LLM_NVIDIA_API_KEY=your-nvapi-key
LLM_NVIDIA_BASE_URL=https://integrate.api.nvidia.com
LLM_NVIDIA_MODEL=meta/llama-3.1-8b-instruct
LLM_NVIDIA_MAX_TOKENS=16384
# Enable chain-of-thought reasoning (slower but more accurate)
LLM_NVIDIA_ENABLE_THINKING=true

# ========================
# LLM Semantic Response Cache
# ========================
# Enable/disable caching of LLM responses
LLM_CACHE_ENABLED=true
# Cosine similarity threshold — responses with similarity >= this will be served from cache
# Range: 0.0 to 1.0 | 0.92 = highly similar prompts only (recommended)
LLM_CACHE_SIMILARITY_THRESHOLD=0.92

# ========================
# STT (Speech-to-Text) — Faster-Whisper (CTranslate2 int8, Vietnamese)
# ========================
# Model size: tiny | base | small | medium  (small = best speed/accuracy for vi)
STT_MODEL_SIZE=small
# Compute type: int8 (VRAM-friendly for ≤4GB GPU) | float16 | float32
STT_COMPUTE_TYPE=int8
# Language hardcoded to Vietnamese — skips detect step
STT_LANGUAGE=vi
STT_DEVICE=cpu

# ========================
# VAD (Voice Activity Detection) — silero-vad
# ========================
# Silence duration (ms) after speech to flush buffer and send to STT (spec: 1200–1500ms)
VAD_SILENCE_THRESHOLD_MS=1300
# Minimum speech duration (ms) before a turn is considered valid
VAD_MIN_SPEECH_DURATION_MS=200

# ========================
# TTS: edge | piper | vieneu
# Edge voices: vi-VN-HoaiMyNeural, vi-VN-NamMinhNeural
# Local VieNeu voices:
#   Bích Ngọc (Nữ - Miền Bắc)
#   Phạm Tuyên (Nam - Miền Bắc)
#   Thục Đoan (Nữ - Miền Nam)
#   Xuân Vĩnh (Nam - Miền Nam)
# ========================
TTS_ENGINE=vieneu
TTS_VOICE=Xuân Vĩnh (Nam - Miền Nam)
TTS_MODEL_PATH=./models/tts/vieneu-turbo/vieneu-tts-v2-turbo.gguf
