# ============================================================
# LancerAI production environment template
# Copy this file to .env on the server and fill real values.
# Do not commit the real .env file.
# ============================================================

# ========================
# Application
# ========================
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_TO_FILE=false
# LOG_DIR=/var/log/lancerai

# ========================
# Auth / JWT
# Generate a strong key: openssl rand -hex 32
# ========================
AUTH_SECRET_KEY=REPLACE_WITH_STRONG_SECRET_MIN_32_CHARS
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=60
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_ALLOW_WEAK_SECRET=false

# ========================
# CORS
# Browser camera/microphone requires HTTPS, except localhost.
# Prefer a real HTTPS domain for live interview demos.
# Replace YOUR_DROPLET_IP with the real server IP, or use https://YOUR_DOMAIN.
# ========================
ALLOWED_ORIGINS=["http://YOUR_DROPLET_IP","http://YOUR_DROPLET_IP:80"]
FRONTEND_BASE_URL=http://YOUR_DROPLET_IP

# ========================
# Database (PostgreSQL)
# docker-compose.prod.yml overrides DATABASE_URL to use the postgres service.
# ========================
DATABASE_URL=postgresql+asyncpg://postgres:REPLACE_PG_PASSWORD@postgres:5432/lancerai
DATABASE_ECHO=false
POSTGRES_DB=lancerai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_PG_PASSWORD

# ========================
# Redis
# ========================
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ========================
# Vector Database (ChromaDB)
# ========================
VECTOR_DB_HOST=http://chromadb
VECTOR_DB_PORT=8000
VECTOR_DB_COLLECTION=cv_embeddings
VECTOR_DB_BACKEND=chroma
VECTOR_DB_API_KEY=

# ========================
# Knowledge Graph (Neo4j)
# ========================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_NEO4J_PASSWORD
NEO4J_AUTH=neo4j/REPLACE_NEO4J_PASSWORD

# ========================
# Local LLM (Ollama)
# Leave localhost if Ollama is installed on the host. Otherwise the app falls
# back to hosted/Groq/NVIDIA providers.
# ========================
LLM_LOCAL_BASE_URL=http://localhost:11434
LLM_LOCAL_MODEL=qwen2.5:3b

# ========================
# Self-hosted Cloud LLM (OpenAI-compatible, optional)
# ========================
LLM_HOSTED_BASE_URL=
LLM_HOSTED_API_KEY=
LLM_HOSTED_MODEL=
LLM_HOSTED_EMBEDDING_MODEL=

# ========================
# Cloud LLM Fallback (Groq API)
# ========================
LLM_CLOUD_API_KEY=REPLACE_GROQ_API_KEY
LLM_CLOUD_BASE_URL=https://api.groq.com/openai/v1
LLM_CLOUD_MODEL=llama-3.1-70b-versatile

# ========================
# NVIDIA NIM API
# ========================
LLM_NVIDIA_API_KEY=REPLACE_NVIDIA_API_KEY
LLM_NVIDIA_BASE_URL=https://integrate.api.nvidia.com
LLM_NVIDIA_MODEL=meta/llama-3.1-8b-instruct
LLM_NVIDIA_MAX_TOKENS=16384
LLM_NVIDIA_ENABLE_THINKING=false

# ========================
# LLM Cache
# ========================
LLM_CACHE_ENABLED=true
LLM_CACHE_SIMILARITY_THRESHOLD=0.92

# ========================
# STT (Speech-to-Text) on CPU
# tiny is recommended for small droplets.
# ========================
STT_MODEL_SIZE=tiny
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=vi
STT_DEVICE=cpu

# ========================
# VAD
# ========================
VAD_SILENCE_THRESHOLD_MS=1300
VAD_MIN_SPEECH_DURATION_MS=200

# ========================
# TTS
# edge-tts avoids local model files and is the safest production default.
# ========================
TTS_ENGINE=edge
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_LOCAL_TIMEOUT_SECONDS=8
# TTS_MODEL_PATH=./models/tts/vieneu-turbo/vieneu-tts-v2-turbo.gguf
