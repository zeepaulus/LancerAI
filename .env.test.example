# ============================================================
# LancerAI CI/test environment template.
# Values are intentionally fake and safe to commit.
# ============================================================

APP_ENV=test
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_TO_FILE=false

AUTH_SECRET_KEY=ci-secret-key-for-lancerai-32chars-minimum
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=60
AUTH_REFRESH_TOKEN_TTL_DAYS=7
AUTH_ALLOW_WEAK_SECRET=false

ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
FRONTEND_BASE_URL=http://localhost:3000

POSTGRES_DB=lancerai_ci
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/lancerai_ci
DATABASE_ECHO=false

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

VECTOR_DB_HOST=tests/.chromadb_ci_data
VECTOR_DB_PORT=8001
VECTOR_DB_COLLECTION=cv_embeddings_ci
VECTOR_DB_BACKEND=chroma
VECTOR_DB_API_KEY=

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=ci-neo4j-password
NEO4J_AUTH=neo4j/ci-neo4j-password

LLM_LOCAL_BASE_URL=http://127.0.0.1:11434
LLM_LOCAL_MODEL=mock-local-model
LLM_HOSTED_BASE_URL=
LLM_HOSTED_API_KEY=
LLM_HOSTED_MODEL=
LLM_HOSTED_EMBEDDING_MODEL=
LLM_CLOUD_API_KEY=
LLM_CLOUD_BASE_URL=https://api.groq.com/openai/v1
LLM_CLOUD_MODEL=mock-cloud-model
LLM_NVIDIA_API_KEY=
LLM_NVIDIA_BASE_URL=https://integrate.api.nvidia.com
LLM_NVIDIA_MODEL=mock-nvidia-model
LLM_NVIDIA_MAX_TOKENS=1024
LLM_NVIDIA_ENABLE_THINKING=false
LLM_CACHE_ENABLED=false
LLM_CACHE_SIMILARITY_THRESHOLD=0.92

STT_MODEL_SIZE=tiny
STT_MODEL_PATH=
STT_COMPUTE_TYPE=int8
STT_LANGUAGE=vi
STT_DEVICE=cpu

VAD_SILENCE_THRESHOLD_MS=1300
VAD_MIN_SPEECH_DURATION_MS=200

TTS_ENGINE=edge
TTS_VOICE=vi-VN-HoaiMyNeural
TTS_LOCAL_TIMEOUT_SECONDS=8
TTS_MODEL_PATH=
